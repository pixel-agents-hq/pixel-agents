# pixel-agents/.env.example — secret var NAMES expected for dev/runtime.
# DO NOT commit values.
#
# Resolution (6-layer, per @minion-stack/env):
#   1. AI/.env.defaults                       (meta-repo non-secret defaults)
#   2. Infisical project minion-core          (shared secrets)
#   3. pixel-agents/.env.defaults             (subproject non-secret defaults)
#   4. Infisical project minion-pixel-agents  (subproject secrets)
#   5. pixel-agents/.env.local                (gitignored dev escape hatch)
#   6. shell process.env                      (wins)
#
# Run `minion sync-env pixel-agents` (or `minion dev pixel-agents`) to merge
# layers 1-4 + 5 and materialize .env.local for native commands.
#
# Note: The extension itself reads no process.env at runtime — env is only
# relevant for dev scripts (scripts/3-vision-inspect.ts uses the Anthropic SDK
# for vision-based asset metadata extraction) and test tooling.

# =============================================================================
# LLM credentials (scripts/3-vision-inspect.ts — @anthropic-ai/sdk vision API)
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# VS Code test runner overrides (optional — set by @vscode/test-electron)
# =============================================================================
# VSCODE_PID is not a secret and not a name you set manually; listed for
# discoverability only. Leave commented unless specifically debugging.
# VSCODE_PID=

# =============================================================================
# Debug / developer flags
# =============================================================================
# Enable verbose debug logging for hook events (SessionStart, SessionEnd, Stop, etc.)
# PIXEL_AGENTS_DEBUG=1
