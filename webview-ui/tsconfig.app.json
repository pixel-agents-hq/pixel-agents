{
  "extends": "@minion-stack/tsconfig/base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "allowUnreachableCode": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    // Transitional overrides — shared base.json enables both strict flags.
    // Webview-ui pre-adoption baseline: 0 errors. Post-adoption without these
    // overrides: 108 new `possibly undefined` errors concentrated in
    // src/office/sprites/spriteData.ts + src/office/wallTiles.ts. Phase 8
    // follow-up will remove these and fix inline.
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": false
  },
  "include": ["src"]
}
